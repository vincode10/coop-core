{
  "name": "coop-core",
  "version": "0.5.1",
  "description": "Shared, domain-agnostic platform plumbing for cooperative apps (CoopBite, Bunji Ride). Zero runtime dependencies.",
  "type": "commonjs",
  "exports": {
    "./secret": "./secret.js",
    "./errors": "./errors.js",
    "./oidc": "./oidc.js",
    "./screening": "./screening.js",
    "./registry": "./registry.js",
    "./payments": "./payments.js",
    "./bank": "./bank.js",
    "./identity": "./identity.js",
    "./mfa": "./mfa.js",
    "./auth": "./auth.js",
    "./notify": "./notify.js",
    "./compliance": "./compliance.js",
    "./store": "./store.js"
  },
  "files": ["*.js"],
  "scripts": {
    "pretest": "node scripts/lint-syntax.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-force-exit tests/*.test.js"
  },
  "engines": { "node": ">=18" },
  "license": "AGPL-3.0",
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3"
  }
}
